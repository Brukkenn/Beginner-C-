//Factorial between 1 and 20.
#include <iostream>
using namespace std;
int main(int argc, char *argv[]){
    int x;
    char c={};
    cout<<"Welcome."<<endl;
    for(;c!='x';){
        int y=1,z=1;
    cout<<"Write a number between 1 and 20 to know it's factorial."<<endl;
    cin>>x;
        if(x<1||x>20){
            cout<<"A number between 1 and 20!"<<endl;
        }else{
            while(y<=x){
                z=z*y;
                y=++y;
            }cout<<"The factorial is "<<z<<"."<<endl;
        }
        cout<<"If you wish to leave, press x, if not, press other key instead."<<endl;
        cin>>c;
    }
    return 0;
}
